datasource db {
  provider = "sqlite"
  url      = "file:./translations.db"
}

generator client {
  provider = "prisma-client-js"
}

model Language {
  bcp47Code     String  @id
  posixCode     String  @unique
  iso639_3Code  String  @unique
  directoryName String  @unique
  englishName   String  @unique
  whisperCode   String?

  proficiencies LanguageProficiency[]
  votes         Vote[]
}

model MasterString {
  id   Int    @id @default(autoincrement())
  text String @unique

  votes Vote[]
}

model LLM {
  name          String                @id
  proficiencies LanguageProficiency[]
  votes         Vote[]
}

model LanguageProficiency {
  llmName       String
  languageBcp47 String
  level         Int

  llm      LLM      @relation(fields: [llmName], references: [name], onDelete: Cascade)
  language Language @relation(fields: [languageBcp47], references: [bcp47Code], onDelete: Cascade)

  @@unique([llmName, languageBcp47])
}

model Vote {
  id             Int      @id @default(autoincrement())
  llmName        String
  masterStringId Int
  languageBcp47  String
  translatedText String
  submittedAt    DateTime @default(now())

  llm          LLM          @relation(fields: [llmName], references: [name], onDelete: Cascade)
  masterString MasterString @relation(fields: [masterStringId], references: [id], onDelete: Cascade)
  language     Language     @relation(fields: [languageBcp47], references: [bcp47Code], onDelete: Cascade)

  @@unique([llmName, masterStringId, languageBcp47, translatedText])
}
